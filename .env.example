APP_ENV=development

# Physical iPhone / Android device on the same Wi-Fi as the backend Mac.
API_BASE_URL=http://<MAC_LOCAL_IP>:3000

# Optional environment-specific URLs.
DEVELOPMENT_API_BASE_URL=http://<MAC_LOCAL_IP>:3000
STAGING_API_BASE_URL=https://staging-api.example.com
PRODUCTION_API_BASE_URL=https://api.example.com

# Optional fallback when API_BASE_URL is not set.
API_LAN_IP=<MAC_LOCAL_IP>
API_PORT=3000
